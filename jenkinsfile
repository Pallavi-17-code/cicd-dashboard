pipeline {
    agent any

    environment {
        DOCKER_HUB_CREDENTIALS = credentials('dockerhub-credentialss')
        IMAGE_NAME = 'pallavigowda02/cicd-dashboard'
    }

    stages {
        stage('Build Docker Image') {
            steps {
                bat 'docker build -t %IMAGE_NAME% .'
            }
        }

        stage('Push to Docker Hub') {
    steps {
        withCredentials([usernamePassword(credentialsId: 'dockerhub-credentialss', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
            bat '''
            echo %PASS% | docker login -u %USER% -p %PASS%"
            docker push pallavigowda02/cicd-dashboard
            '''
        }
    }
}

        stage('Run Docker Container') {
            steps {
                bat 'docker stop cicd-app || exit 0'
                bat 'docker rm cicd-app || exit 0'
                bat 'docker run -d -p 4000:3000 --name cicd-app%IMAGE_NAME%'
            }
        }
    }

    post {
        always {
            bat 'docker logout'
        }
    }
}