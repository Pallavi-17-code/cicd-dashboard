pipeline {
    agent any

    environment {
        DOCKER_HUB_CREDENTIALS = credentials('dockerhub-credentialsss')
        IMAGE_NAME = 'pallavigowda02/cicd-dashboard'
        IMAGE_TAG = 'latest'  // Add explicit versioning
    }

    stages {
        stage('Build Docker Image') {
            steps {
                bat "docker build -t %IMAGE_NAME%:%IMAGE_TAG% ."
            }
        }

        stage('Push to Docker Hub') {
    steps {
        bat "docker login -u pallavigowda02 -p YOUR_TOKEN_HERE"
        bat "docker push pallavigowda02/cicd-dashboard"
    }
}
                }

        stage('Run Docker Container') {
            steps {
                bat 'docker stop cicd-app || exit 0'
                bat 'docker rm cicd-app || exit 0'
                bat "docker run -d -p 4000:3000 --name cicd-app %IMAGE_NAME%:%IMAGE_TAG%"
            }
        }
    }

    post {
        always {
            bat 'docker logout'
        }
    }
}