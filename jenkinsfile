pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                bat 'npm install'
            }
        }

        stage('Build Docker Image') {
            steps {
                bat 'docker build -t cicd-dashboard .'
            }
        }

        stage('Run Docker Container') {
            steps {
                bat 'docker run -d -p 4000:3000 cicd-dashboard'
            }
        }
    }
}