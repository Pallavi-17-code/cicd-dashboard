pipeline {
    agent any

    environment {
        IMAGE_NAME = 'pallavigowda02/cicd-dashboard'
        IMAGE_TAG = 'latest'
    }

    stages {
        stage('Build Docker Image') {
            steps {
                bat "docker build -t %IMAGE_NAME%:%IMAGE_TAG% ."
            }
        }

        stage('Push to Docker Hub') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'Dockerhub-credentialss', usernameVariable: 'USER', passwordVariable: 'PASS')]) {
                    bat 'echo %PASS% | docker login -u %USER% --password-stdin'
                    bat 'docker push pallavigowda02/cicd-dashboard:latest'
                    bat 'docker logout'
                }
            }
        }

        stage('Run Docker Container') {
            steps {
                bat 'docker stop cicd-app || exit 0'
                bat 'docker rm cicd-app || exit 0'
                // Kill any process using port 4000
                bat 'FOR /F "tokens=5" %%a IN (\'netstat -aon ^| findstr :4000\') DO taskkill /F /PID %%a || exit 0'
                bat 'docker run -d -p 4000:3000 --name cicd-app pallavigowda02/cicd-dashboard:latest'
            }
        }
    }

    post {
        always {
            bat 'docker logout'
        }
    }
}